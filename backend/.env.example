# Required for Gemini-based reading, chat, and report generation
GEMINI_API_KEY=your_gemini_api_key_here

# Required for Qwen models and Deep Research retrieval/rerank
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Optional: override the DashScope OpenAI-compatible endpoint
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional: required only for uploading research packs to GitHub Releases
# GITHUB_TOKEN=ghp_xxx
